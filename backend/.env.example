# Copia este archivo a .env y sustituye TODOS los valores REPLACE_ME antes de desplegar.
# NUNCA subas .env real a git. Ya esta en .gitignore.

ENVIRONMENT=development
DEBUG=true

# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://cyberscan:REPLACE_ME_LOCAL_DB_PASSWORD@localhost:5432/cyberscan

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# --- Auth0 (crear tenant en https://manage.auth0.com) ---
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_API_AUDIENCE=https://api.cyberscan.ai
AUTH0_CLIENT_ID=REPLACE_ME_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=REPLACE_ME_AUTH0_CLIENT_SECRET

# --- Integraciones de threat intel (cada una requiere cuenta propia) ---
# VirusTotal: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=REPLACE_ME_VT_API_KEY
# Shodan: https://account.shodan.io/
SHODAN_API_KEY=REPLACE_ME_SHODAN_API_KEY
# AbuseIPDB: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=REPLACE_ME_ABUSEIPDB_API_KEY
# HaveIBeenPwned (OPCIONAL, ya NO se usa por defecto - su API es 100% de pago
# desde 2024, sin tier gratuito). El modulo activo de correo usa XposedOrNot,
# que es gratuito y no requiere key. Deja esto como esta salvo que decidas
# pagar HIBP en el futuro: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=REPLACE_ME_HIBP_API_KEY
# NumVerify - GRATUITO (100 requests/mes, solo requiere registro sin tarjeta):
# https://numverify.com -> Sign Up -> copia tu API Access Key
NUMVERIFY_API_KEY=REPLACE_ME_NUMVERIFY_API_KEY

# --- AWS / S3 ---
AWS_REGION=us-east-1
S3_BUCKET_REPORTS=cyberscan-ai-reports
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME

RATE_LIMIT_PER_MINUTE=10
ALLOWED_ORIGINS=http://localhost:3000
